---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Holistic Facial Rituals"
  description="Botanical facials that nourish, detoxify, and illuminate your natural radiance at Saltay Hanalei Bay."
>

  <section class="page-hero">
    <span class="page-hero__eyebrow">Signature Offerings</span>
    <h1 class="page-hero__heading">Holistic Facial Rituals</h1>
    <img src="/icons/spiral-rule.svg" class="page-hero__rule" alt="" aria-hidden="true" />
    <p class="page-hero__body">
      Botanical facials that nourish, detoxify, and illuminate your natural radiance.
    </p>
  </section>

  <section class="offering-detail">
    <div class="offering-detail__inner">

      <div class="offering-detail__image">
        <img
          src="https://images.unsplash.com/photo-1761718210089-ba3bb5ccb54f?q=80&w=800&auto=format&fit=crop"
          alt="Person receiving a holistic facial treatment"
          loading="lazy"
        />
      </div>

      <div class="offering-detail__content">
        <span class="u-label">About This Service</span>

        <p class="offering-detail__body">
          Our holistic facial rituals go far beyond surface-level skincare. Each treatment
          begins with a thorough skin consultation and is customized using premium botanical
          actives, adaptogenic plant extracts, and ancient facial massage techniques that
          work on both the physical and energetic layers of the skin.
        </p>
        <p class="offering-detail__body">
          Techniques may include gua sha, lymphatic drainage, jade rolling, and facial
          acupressure — restoring radiance from the inside out.
        </p>

        <ul class="offering-detail__benefits" aria-label="Benefits">
          <li class="offering-detail__benefit">Deep cleansing and pore refinement</li>
          <li class="offering-detail__benefit">Brightens skin tone and reduces hyperpigmentation</li>
          <li class="offering-detail__benefit">Stimulates collagen and improves facial contour</li>
          <li class="offering-detail__benefit">Relieves jaw tension and sinus congestion</li>
          <li class="offering-detail__benefit">Activates lymphatic flow for depuffing and clarity</li>
        </ul>

        <div style="margin-top: 0.5rem;">
          <a href="/booking/" class="btn btn--primary">Book This Service</a>
        </div>
      </div>

    </div>
  </section>

  <section class="page-cta" aria-labelledby="facial-cta">
    <div class="page-cta__inner">
      <h2 class="page-cta__heading" id="facial-cta">Explore more offerings</h2>
      <p class="page-cta__body">Elevated Healing. Lasting Transformation.</p>
      <a href="/offerings/" class="btn btn--outline">View All Services</a>
    </div>
  </section>

</BaseLayout>
