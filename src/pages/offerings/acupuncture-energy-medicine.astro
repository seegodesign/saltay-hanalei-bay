---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Acupuncture & Energy Medicine"
  description="Ancient techniques that balance energy, support healing, and optimize well-being at Saltay Hanalei Bay."
>

  <section class="page-hero">
    <span class="page-hero__eyebrow">Signature Offerings</span>
    <h1 class="page-hero__heading">Acupuncture &amp; Energy Medicine</h1>
    <span class="page-hero__rule" aria-hidden="true"></span>
    <p class="page-hero__body">
      Ancient techniques that balance energy, support healing, and optimize well-being.
    </p>
  </section>

  <section class="offering-detail">
    <div class="offering-detail__inner">

      <div class="offering-detail__image" aria-hidden="true"></div>

      <div class="offering-detail__content">
        <span class="u-label">About This Service</span>

        <p class="offering-detail__body">
          Rooted in thousands of years of traditional Chinese medicine, our acupuncture
          and energy medicine sessions work with your body's meridian pathways to clear
          blockages, restore vital energy flow, and activate your innate healing capacity.
        </p>
        <p class="offering-detail__body">
          Sessions may incorporate traditional needling, moxibustion, tuning fork
          therapy, and biofield techniques — each chosen to address your unique
          energetic constitution and wellness goals.
        </p>

        <ul class="offering-detail__benefits" aria-label="Benefits">
          <li class="offering-detail__benefit">Rebalances the body's vital energy (Qi/Prana)</li>
          <li class="offering-detail__benefit">Reduces inflammation and supports immune function</li>
          <li class="offering-detail__benefit">Alleviates pain and chronic stress patterns</li>
          <li class="offering-detail__benefit">Supports hormonal balance and adrenal recovery</li>
          <li class="offering-detail__benefit">Clears emotional and energetic stagnation</li>
        </ul>

        <div style="margin-top: 0.5rem;">
          <a href="/booking/" class="btn btn--primary">Book This Service</a>
        </div>
      </div>

    </div>
  </section>

  <section class="page-cta" aria-labelledby="acu-cta">
    <div class="page-cta__inner">
      <h2 class="page-cta__heading" id="acu-cta">Explore more offerings</h2>
      <p class="page-cta__body">Elevated Healing. Lasting Transformation.</p>
      <a href="/offerings/" class="btn btn--outline">View All Services</a>
    </div>
  </section>

</BaseLayout>
