---
import BaseLayout from '../../layouts/BaseLayout.astro';

const offerings = [
  {
    slug: 'massage-bodywork',
    title: 'Massage & Bodywork',
    body: 'Therapeutic touch to release tension, improve circulation, and restore balance.',
    image: 'https://plus.unsplash.com/premium_photo-1661757559191-46925b9a526f?q=80&w=600&auto=format&fit=crop',
    imageAlt: 'Woman receiving a relaxing back massage at a spa',
  },
  {
    slug: 'acupuncture-energy-medicine',
    title: 'Acupuncture & Energy Medicine',
    body: 'Ancient techniques that balance energy, support healing, and optimize well-being.',
    image: 'https://images.unsplash.com/photo-1523681504355-8b4860f99a58?q=80&w=600&auto=format&fit=crop',
    imageAlt: 'Black ceramic Buddha figurine symbolizing energy and spirituality',
  },
  {
    slug: 'holistic-facial-rituals',
    title: 'Holistic Facial Rituals',
    body: 'Botanical facials that nourish, detoxify, and illuminate your natural radiance.',
    image: 'https://images.unsplash.com/photo-1761718210089-ba3bb5ccb54f?q=80&w=600&auto=format&fit=crop',
    imageAlt: 'Person receiving a holistic facial treatment',
  },
  {
    slug: 'infrared-sauna',
    title: 'Infrared Sauna',
    body: 'Deep detoxification, cellular rejuvenation, and relaxation through infrared heat.',
    image: 'https://images.unsplash.com/photo-1741601273168-04934064889f?q=80&w=600&auto=format&fit=crop',
    imageAlt: 'Man relaxing in a steamy infrared sauna',
  },
  {
    slug: 'sound-healing',
    title: 'Sound Healing',
    body: 'Therapeutic sound journeys that calm the nervous system and restore energetic harmony.',
    image: 'https://plus.unsplash.com/premium_photo-1689254722413-39d278eaf6d6?q=80&w=600&auto=format&fit=crop',
    imageAlt: 'Group in a sound healing session lying on the floor',
  },
  {
    slug: 'remote-sessions',
    title: 'Remote Sessions',
    body: 'Metaphysical & energetic healing sessions from anywhere in the world.',
    image: 'https://images.unsplash.com/photo-1526779259212-939e64788e3c?q=80&w=600&auto=format&fit=crop',
    imageAlt: 'Man sitting alone on a rock surrounded by water in serene contemplation',
  },
  {
    slug: 'wellness-retreats',
    title: 'Wellness Retreats',
    body: 'Immersive retreats and immersions to reset, reconnect, and transform.',
    image: 'https://plus.unsplash.com/premium_photo-1725983645487-5ea02c65ecaf?q=80&w=600&auto=format&fit=crop',
    imageAlt: 'Two women practicing yoga in a lush forest setting',
  },
];
---

<BaseLayout
  title="Offerings"
  description="Explore our signature wellness offerings — from massage and acupuncture to sound healing, infrared sauna, and immersive wellness retreats."
>

  <section class="page-hero">
    <span class="page-hero__eyebrow">What We Offer</span>
    <h1 class="page-hero__heading">Our Signature Wellness Offerings</h1>
    <img src="/icons/spiral-rule.svg" class="page-hero__rule" alt="" aria-hidden="true" />
    <p class="page-hero__body">
      Each offering is a doorway to deeper healing — crafted to meet you exactly
      where you are and guide you toward your highest well-being.
    </p>
  </section>

  <section class="offerings-index">
    <div class="offerings-index__inner">
      <span class="u-label">All Services</span>
      <div class="offerings-index__grid">
        {offerings.map((o) => (
          <a href={`/offerings/${o.slug}/`} class="offerings-index-card">
            <div class="offerings-index-card__image">
              <img src={o.image} alt={o.imageAlt} loading="lazy" />
            </div>
            <p class="offerings-index-card__title">{o.title}</p>
            <p class="offerings-index-card__body">{o.body}</p>
            <span class="offerings-index-card__cta" aria-hidden="true">
              Learn more &rsaquo;
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="page-cta" aria-labelledby="offerings-cta-heading">
    <div class="page-cta__inner">
      <h2 class="page-cta__heading" id="offerings-cta-heading">
        Ready to begin your journey?
      </h2>
      <p class="page-cta__body">Elevated Healing. Lasting Transformation.</p>
      <a href="/booking/" class="btn btn--primary">Book Your Experience</a>
    </div>
  </section>

</BaseLayout>
