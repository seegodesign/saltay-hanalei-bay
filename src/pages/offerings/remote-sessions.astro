---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Remote Sessions"
  description="Metaphysical and energetic healing sessions available from anywhere in the world at Saltay Hanalei Bay."
>

  <section class="page-hero">
    <span class="page-hero__eyebrow">Signature Offerings</span>
    <h1 class="page-hero__heading">Remote Sessions</h1>
    <img src="/icons/spiral-rule.svg" class="page-hero__rule" alt="" aria-hidden="true" />
    <p class="page-hero__body">
      Metaphysical &amp; energetic healing sessions from anywhere in the world.
    </p>
  </section>

  <section class="offering-detail">
    <div class="offering-detail__inner">

      <div class="offering-detail__image">
        <img
          src="https://images.unsplash.com/photo-1526779259212-939e64788e3c?q=80&w=800&auto=format&fit=crop"
          alt="Man sitting alone on a rock surrounded by calm water in serene contemplation"
          loading="lazy"
        />
      </div>

      <div class="offering-detail__content">
        <span class="u-label">About This Service</span>

        <p class="offering-detail__body">
          Healing transcends physical location. Our remote sessions harness the power
          of quantum energy principles and distance healing modalities to deliver
          profound energetic transformation — wherever you are in the world.
        </p>
        <p class="offering-detail__body">
          Sessions may include remote reiki, biofield clearing, intuitive energy
          assessment, chakra balancing, and guided meditative journeys — all conducted
          via secure video call or, in certain modalities, purely at the energetic level.
        </p>

        <ul class="offering-detail__benefits" aria-label="Benefits">
          <li class="offering-detail__benefit">Access healing from the comfort of your own home</li>
          <li class="offering-detail__benefit">Clears energetic patterns and auric disturbances</li>
          <li class="offering-detail__benefit">Supports emotional and spiritual breakthroughs</li>
          <li class="offering-detail__benefit">Rebalances chakras and subtle energy bodies</li>
          <li class="offering-detail__benefit">Ideal for those with limited mobility or travel constraints</li>
        </ul>

        <div style="margin-top: 0.5rem;">
          <a href="/booking/" class="btn btn--primary">Book This Service</a>
        </div>
      </div>

    </div>
  </section>

  <section class="page-cta" aria-labelledby="remote-cta">
    <div class="page-cta__inner">
      <h2 class="page-cta__heading" id="remote-cta">Explore more offerings</h2>
      <p class="page-cta__body">Elevated Healing. Lasting Transformation.</p>
      <a href="/offerings/" class="btn btn--outline">View All Services</a>
    </div>
  </section>

</BaseLayout>
