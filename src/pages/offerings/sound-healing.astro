---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Sound Healing"
  description="Therapeutic sound journeys that calm the nervous system and restore energetic harmony at Saltay Hanalei Bay."
>

  <section class="page-hero">
    <span class="page-hero__eyebrow">Signature Offerings</span>
    <h1 class="page-hero__heading">Sound Healing</h1>
    <img src="/icons/spiral-rule.svg" class="page-hero__rule" alt="" aria-hidden="true" />
    <p class="page-hero__body">
      Therapeutic sound journeys that calm the nervous system and restore energetic harmony.
    </p>
  </section>

  <section class="offering-detail">
    <div class="offering-detail__inner">

      <div class="offering-detail__image">
        <img
          src="https://plus.unsplash.com/premium_photo-1689254722413-39d278eaf6d6?q=80&w=800&auto=format&fit=crop"
          alt="Group lying on the floor during a sound healing session"
          loading="lazy"
        />
      </div>

      <div class="offering-detail__content">
        <span class="u-label">About This Service</span>

        <p class="offering-detail__body">
          Sound has been used as a healing modality across cultures for thousands of years.
          Our sound healing sessions use crystal singing bowls, Tibetan bowls, tuning forks,
          and other instruments whose frequencies are carefully selected to guide your
          nervous system from a state of stress into deep restoration.
        </p>
        <p class="offering-detail__body">
          Sessions are available as individual treatments, partner journeys, or immersive
          group sound baths — each one a portal to stillness, clarity, and energetic
          realignment.
        </p>

        <ul class="offering-detail__benefits" aria-label="Benefits">
          <li class="offering-detail__benefit">Shifts brainwaves from beta into theta and delta states</li>
          <li class="offering-detail__benefit">Reduces anxiety, depression, and chronic stress</li>
          <li class="offering-detail__benefit">Clears energetic blockages and promotes flow</li>
          <li class="offering-detail__benefit">Deepens meditation and inner awareness</li>
          <li class="offering-detail__benefit">Supports emotional processing and release</li>
        </ul>

        <div style="margin-top: 0.5rem;">
          <a href="/booking/" class="btn btn--primary">Book This Service</a>
        </div>
      </div>

    </div>
  </section>

  <section class="page-cta" aria-labelledby="sound-cta">
    <div class="page-cta__inner">
      <h2 class="page-cta__heading" id="sound-cta">Explore more offerings</h2>
      <p class="page-cta__body">Elevated Healing. Lasting Transformation.</p>
      <a href="/offerings/" class="btn btn--outline">View All Services</a>
    </div>
  </section>

</BaseLayout>
