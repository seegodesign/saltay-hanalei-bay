---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Infrared Sauna"
  description="Deep detoxification, cellular rejuvenation, and relaxation through infrared heat at Saltay Hanalei Bay."
>

  <section class="page-hero">
    <span class="page-hero__eyebrow">Signature Offerings</span>
    <h1 class="page-hero__heading">Infrared Sauna</h1>
    <span class="page-hero__rule" aria-hidden="true"></span>
    <p class="page-hero__body">
      Deep detoxification, cellular rejuvenation, and relaxation through infrared heat.
    </p>
  </section>

  <section class="offering-detail">
    <div class="offering-detail__inner">

      <div class="offering-detail__image" aria-hidden="true"></div>

      <div class="offering-detail__content">
        <span class="u-label">About This Service</span>

        <p class="offering-detail__body">
          Unlike traditional saunas that heat the air around you, our full-spectrum
          infrared sauna penetrates directly into your tissues — raising core body
          temperature and activating deep cellular cleansing at a comfortable, lower
          ambient temperature.
        </p>
        <p class="offering-detail__body">
          Sessions can be tailored for detoxification, athletic recovery, immune
          support, skin rejuvenation, or pure relaxation. Optional chromotherapy
          lighting enhances each experience.
        </p>

        <ul class="offering-detail__benefits" aria-label="Benefits">
          <li class="offering-detail__benefit">Eliminates heavy metals and environmental toxins through sweat</li>
          <li class="offering-detail__benefit">Supports cardiovascular health and circulation</li>
          <li class="offering-detail__benefit">Accelerates muscle recovery and reduces soreness</li>
          <li class="offering-detail__benefit">Stimulates collagen production and skin clarity</li>
          <li class="offering-detail__benefit">Promotes deep relaxation and nervous system reset</li>
        </ul>

        <div style="margin-top: 0.5rem;">
          <a href="/booking/" class="btn btn--primary">Book This Service</a>
        </div>
      </div>

    </div>
  </section>

  <section class="page-cta" aria-labelledby="sauna-cta">
    <div class="page-cta__inner">
      <h2 class="page-cta__heading" id="sauna-cta">Explore more offerings</h2>
      <p class="page-cta__body">Elevated Healing. Lasting Transformation.</p>
      <a href="/offerings/" class="btn btn--outline">View All Services</a>
    </div>
  </section>

</BaseLayout>
