---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Massage & Bodywork"
  description="Therapeutic touch to release tension, improve circulation, and restore balance at Saltay Hanalei Bay."
>

  <section class="page-hero">
    <span class="page-hero__eyebrow">Signature Offerings</span>
    <h1 class="page-hero__heading">Massage &amp; Bodywork</h1>
    <img src="/icons/spiral-rule.svg" class="page-hero__rule" alt="" aria-hidden="true" />
    <p class="page-hero__body">
      Therapeutic touch to release tension, improve circulation, and restore balance.
    </p>
  </section>

  <section class="offering-detail">
    <div class="offering-detail__inner">

      <!-- Replace with <img> once imagery is available -->
      <div class="offering-detail__image">
        <img
          src="https://plus.unsplash.com/premium_photo-1661757559191-46925b9a526f?q=80&w=800&auto=format&fit=crop"
          alt="Woman receiving a relaxing back massage at a spa"
          loading="lazy"
        />
      </div>

      <div class="offering-detail__content">
        <span class="u-label">About This Service</span>

        <p class="offering-detail__body">
          Our Massage &amp; Bodywork offerings blend Eastern and Western therapeutic
          techniques to create a deeply restorative experience. Whether you seek relief
          from chronic tension, recovery from physical strain, or simply a moment of
          profound relaxation, our skilled therapists craft each session to your
          individual needs.
        </p>
        <p class="offering-detail__body">
          Drawing from modalities including Swedish, deep tissue, lymphatic drainage,
          and traditional Hawaiian Lomi Lomi, each session restores your body's natural
          flow and harmony.
        </p>

        <ul class="offering-detail__benefits" aria-label="Benefits">
          <li class="offering-detail__benefit">Releases chronic muscle tension and adhesions</li>
          <li class="offering-detail__benefit">Improves circulation and lymphatic flow</li>
          <li class="offering-detail__benefit">Reduces cortisol and promotes deep relaxation</li>
          <li class="offering-detail__benefit">Supports recovery and restores range of motion</li>
          <li class="offering-detail__benefit">Deepens the mind-body connection</li>
        </ul>

        <div style="margin-top: 0.5rem;">
          <a href="/booking/" class="btn btn--primary">Book This Service</a>
        </div>
      </div>

    </div>
  </section>

  <section class="page-cta" aria-labelledby="massage-cta">
    <div class="page-cta__inner">
      <h2 class="page-cta__heading" id="massage-cta">
        Explore more offerings
      </h2>
      <p class="page-cta__body">Elevated Healing. Lasting Transformation.</p>
      <a href="/offerings/" class="btn btn--outline">View All Services</a>
    </div>
  </section>

</BaseLayout>
