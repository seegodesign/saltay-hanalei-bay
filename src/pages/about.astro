---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="Learn about Saltay Hanalei Bay — a sanctuary for luxury wellness, holistic healing, and transformational care on the shores of Kauai."
>

  <section class="page-hero">
    <span class="page-hero__eyebrow">Our Story</span>
    <h1 class="page-hero__heading">About Saltay Hanalei Bay</h1>
    <span class="page-hero__rule" aria-hidden="true"></span>
    <p class="page-hero__body">
      A sanctuary where ancient healing wisdom meets luxury,
      spirituality, and transformational care.
    </p>
  </section>

  <section class="about-section">
    <div class="about-section__inner">

      <!-- Replace with actual imagery -->
      <div class="about-section__image" aria-hidden="true"></div>

      <div class="about-section__content">
        <span class="u-label">Who We Are</span>
        <h2 class="about-section__heading">
          A Place of Sacred Restoration
        </h2>
        <p class="about-section__body">
          Saltay Hanalei Bay was born from a deep reverence for the healing power of
          nature and the timeless wisdom of ancient therapeutic traditions. Situated
          on the sacred shores of Hanalei Bay in Kauai, we created a space where the
          land's own healing energy amplifies every treatment and every breath.
        </p>
        <p class="about-section__body">
          Our practitioners bring decades of combined expertise across massage therapy,
          acupuncture, energy medicine, botanical skincare, and metaphysical healing —
          united by a shared philosophy: that true wellness is an integration of body,
          mind, spirit, and energy.
        </p>
        <p class="about-section__body">
          We believe every person carries within them the capacity for extraordinary
          healing. Our role is simply to create the conditions for that healing to
          emerge — through exquisite touch, sacred space, and the finest botanical
          and energetic tools available.
        </p>
        <a href="/booking/" class="btn btn--outline-dark" style="margin-top: 0.5rem;">
          Begin Your Journey
        </a>
      </div>

    </div>
  </section>

  <section class="about-values">
    <div class="about-values__inner">
      <span class="u-label">What We Stand For</span>
      <div class="about-values__grid">

        <div class="value-card">
          <img src="/icons/lotus.svg" alt="" class="value-card__icon" width="40" height="40" aria-hidden="true" />
          <p class="value-card__title">Integrative Healing</p>
          <p class="value-card__body">
            We honor the full spectrum of healing — physical, emotional, energetic,
            and spiritual — weaving modalities that speak to each dimension.
          </p>
        </div>

        <div class="value-card">
          <img src="/icons/sun.svg" alt="" class="value-card__icon" width="40" height="40" aria-hidden="true" />
          <p class="value-card__title">Personalized Care</p>
          <p class="value-card__body">
            No two clients are the same. Every session begins with deep listening
            and is crafted uniquely for you — your body, your goals, your timing.
          </p>
        </div>

        <div class="value-card">
          <img src="/icons/spiral.svg" alt="" class="value-card__icon" width="40" height="40" aria-hidden="true" />
          <p class="value-card__title">Sacred Luxury</p>
          <p class="value-card__body">
            We believe the environment is part of the medicine. Every detail —
            from the botanicals we use to the music we play — is chosen with intention.
          </p>
        </div>

      </div>
    </div>
  </section>

  <section class="page-cta" aria-labelledby="about-cta">
    <div class="page-cta__inner">
      <h2 class="page-cta__heading" id="about-cta">
        Come experience it for yourself
      </h2>
      <p class="page-cta__body">Elevated Healing. Lasting Transformation.</p>
      <a href="/booking/" class="btn btn--primary">Book Your Experience</a>
    </div>
  </section>

</BaseLayout>
